# ─────────────────────────────────────────────────────────────────────────────
# SentinelAI Backend — Environment Variables
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Existing FastAPI (backend/main.py) settings ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
USE_LLM_EXTRACTION=false
USE_LLM_CHAT=false
OPENAI_API_KEY=your_openai_api_key_here
USE_OPENAI_EXTRACTION=false
DEFAULT_CITY=Bengaluru
DEFAULT_STATE=Karnataka
DEFAULT_COUNTRY=India

# ── Flask App (backend/app.py) settings ───────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinelai

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET_KEY=change-me-before-deploying-to-production
JWT_ACCESS_TOKEN_HOURS=8

# ML Model directory (default: ../trained_model/ relative to backend/)
# CATBOOST_MODEL_DIR=../trained_model/
# FAISS_INDEX_PATH=../Resource Intelligence and Historical Operation Module/faiss_index/

# Sentence Transformer model name
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Readiness score weights (must sum <= 1.0; penalty is subtracted)
# WEIGHT_OFFICER=0.35
# WEIGHT_VEHICLE=0.30
# WEIGHT_TOW=0.15
# WEIGHT_BARRICADE=0.10
# WEIGHT_PENALTY=0.10

# Rate limiting
# RATELIMIT_DEFAULT=100 per minute

# Account lockout
# MAX_LOGIN_ATTEMPTS=5
# ACCOUNT_LOCK_MINUTES=30

# CORS — set to your frontend origin in production
# CORS_ORIGINS=http://localhost:5173

# Cache TTLs (seconds)
# STATION_LIST_CACHE_TTL=30
# READINESS_CACHE_TTL=60
