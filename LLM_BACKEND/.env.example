# Gemini API Configuration
GEMINI_API_KEY=your_key_here

# Enable LLM-based extraction (set to false to use rule-based extraction only)
USE_LLM_EXTRACTION=true

# Enable LLM-based chat for incident questions
USE_LLM_CHAT=true

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
USE_OPENAI_EXTRACTION=true

# Default location for geocoding fallback
DEFAULT_CITY=Coimbatore
DEFAULT_STATE=Tamil Nadu
DEFAULT_COUNTRY=India
